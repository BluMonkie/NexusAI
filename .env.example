# NEXUS IQ — Environment Variables
# Copy this file to .env and fill in your values

# AI Engine Mode: 'simulated' | 'openai' | 'gemini'
# Leave as 'simulated' for demo mode (no API key needed)
VITE_AI_MODE=simulated

# OpenAI API Key (required when VITE_AI_MODE=openai)
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# OpenAI Model (default: gpt-4o)
VITE_AI_MODEL=gpt-4o

# Google Gemini API Key (required when VITE_AI_MODE=gemini)
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
